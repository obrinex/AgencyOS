# Do not commit real values. Set these as encrypted environment variables in your host.
APP_ENV=production
MONGO_URL=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
DB_NAME=agencyos
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=use-a-unique-password-with-14-or-more-characters
JWT_SECRET=generate-a-unique-64-character-secret
VAULT_ENCRYPTION_KEY=generate-a-fernet-key
FRONTEND_URL=https://dashboard.example.com
CORS_ORIGINS=https://dashboard.example.com
ALLOWED_HOSTS=api.example.com
COOKIE_SECURE=true
# Use none only while the dashboard is on a different site (for example,
# *.vercel.app calling *.onrender.com). Prefer lax with custom subdomains.
COOKIE_SAMESITE=lax
SENDER_EMAIL=billing@example.com
RESEND_API_KEY=inject-from-your-host-secret-manager
