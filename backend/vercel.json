{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/automations/cron/daily",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/automations/cron/reminders",
      "schedule": "0 14 * * *"
    }
  ]
}
